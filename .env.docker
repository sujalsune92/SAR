# ════════════════════════════════════════════════════════
# Docker Environment Configuration
# ════════════════════════════════════════════════════════

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sar_audit
POSTGRES_PORT=5432

# Backend Configuration
BACKEND_PORT=8000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sar_audit
CHROMA_DB_PATH=/app/rag_pipeline/vector_db
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_PORT=11434

# Security
JWT_SECRET_KEY=sar-narrative-secret-change-in-production

# Application
ENVIRONMENT=development
LOG_LEVEL=info

# Frontend Configuration
FRONTEND_PORT=8080

# Default Credentials (Change in production)
DEFAULT_USERNAME=analyst
DEFAULT_PASSWORD=password123
