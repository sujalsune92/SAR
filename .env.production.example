# Production profile
ENVIRONMENT=production
LOG_LEVEL=info

# Security - set through secret manager in CI/CD
JWT_SECRET_KEY=REPLACE_IN_SECRET_MANAGER

# Database - do not commit real values
POSTGRES_USER=REPLACE_DB_USER
POSTGRES_PASSWORD=REPLACE_DB_PASSWORD
POSTGRES_DB=sar_audit
POSTGRES_PORT=5432
DATABASE_URL=postgresql://REPLACE_DB_USER:REPLACE_DB_PASSWORD@postgres:5432/sar_audit

# Runtime services
BACKEND_PORT=8000
FRONTEND_PORT=80
OLLAMA_HOST=http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434
OLLAMA_MODEL=mistral:7b
CHROMA_DB_PATH=/app/rag_pipeline/vector_db
DATA_FOLDER=/app/data
